# /etc/bristlecone/app.env
# Copy this file and set your production values.

NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Recording
RECORDING_S3_BUCKET=
RECORDING_S3_REGION=us-east-1
RECORDING_S3_PREFIX=recordings

# Prisma runtime DB path used by deploy scripts
DATABASE_URL=file:./prisma/.runtime/interviewbot.db
