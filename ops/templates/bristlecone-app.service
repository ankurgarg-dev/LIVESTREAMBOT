[Unit]
Description=Bristlecone Technical Interaction (Next.js)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/bristlecone-app
EnvironmentFile=-/etc/bristlecone/app.env
Environment=NODE_ENV=production
ExecStart=/usr/bin/env pnpm start --hostname 0.0.0.0 --port 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
