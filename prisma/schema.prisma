generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Interview {
  id            String   @id
  roomName      String
  candidateName String
  status        String
  agentType     String
  createdAt     DateTime
  updatedAt     DateTime
  payload       Json

  @@index([roomName, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model Position {
  id        String   @id
  roleTitle String
  createdAt DateTime
  updatedAt DateTime
  payload   Json

  @@index([updatedAt(sort: Desc)])
}

model Candidate {
  id        String   @id
  fullName  String
  email     String
  createdAt DateTime
  updatedAt DateTime
  payload   Json

  applications CandidateApplication[]

  @@index([email])
  @@index([updatedAt(sort: Desc)])
}

model AgentSetting {
  id        Int      @id
  payload   Json
  updatedAt DateTime
}

model CandidateApplication {
  id           String   @id
  positionId   String
  candidateId  String?
  candidateName String
  candidateEmail String
  overallScore Int
  recommendation String
  createdAt    DateTime
  updatedAt    DateTime
  payload      Json

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, positionId])
  @@index([positionId, updatedAt(sort: Desc)])
  @@index([candidateId, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}


model Skill {
  id            Int              @id @default(autoincrement())
  canonicalName String           @map("canonical_name")
  skillType     String           @default("GENERAL") @map("skill_type")
  status        String           @default("ACTIVE")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @map("updated_at")
  aliases       SkillAlias[]
  blockRules    SkillBlockRule[]

  @@index([canonicalName])
  @@map("skills")
}

model SkillAlias {
  id         Int      @id @default(autoincrement())
  skillId    Int      @map("skill_id")
  aliasText  String   @map("alias_text")
  matchType  String   @map("match_type")
  confidence Float    @default(1.0)
  tenantId   String?  @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([aliasText])
  @@index([skillId])
  @@map("skill_aliases")
}

model SkillBlockRule {
  id            Int      @id @default(autoincrement())
  blocksSkillId Int      @map("blocks_skill_id")
  patternText   String   @map("pattern_text")
  matchType     String   @map("match_type")
  tenantId      String?  @map("tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  blocksSkill   Skill    @relation(fields: [blocksSkillId], references: [id], onDelete: Cascade)

  @@index([patternText])
  @@index([blocksSkillId])
  @@map("skill_block_rules")
}

model SkillRulesetVersion {
  id          Int      @id @default(autoincrement())
  versionName String   @map("version_name")
  versionHash String   @map("version_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([versionName])
  @@unique([versionHash])
  @@map("skill_ruleset_versions")
}
